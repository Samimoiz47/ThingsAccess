{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "env": {
    "APP_NAME": "Things Access",
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "https://thingsaccess-company-web1.vercel.app",
    "ASSET_URL": "https://thingsaccess-company-web1.vercel.app",
    "APP_KEY": "base64:WL2SrAKzxdXk75OH4lcvCU4Gow2wRzYtF7ZDseFbsjA=",
    "CACHE_STORE": "array",
    "SESSION_DRIVER": "cookie",
    "LOG_CHANNEL": "stderr"
  },
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/public/images/$1"
    },
    {
      "src": "/videos/(.*)",
      "dest": "/public/videos/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
