{
  "version": 2,
  "buildCommand": "npm run build",
  "env": {
    "APP_NAME": "Things Access",
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "https://thingsaccess-company-web1.vercel.app",
    "ASSET_URL": "https://thingsaccess-company-web1.vercel.app",
    "APP_KEY": "base64:WL2SrAKzxdXk75OH4lcvCU4Gow2wRzYtF7ZDseFbsjA=",
    "CACHE_STORE": "array",
    "SESSION_DRIVER": "cookie",
    "LOG_CHANNEL": "stderr"
  },
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    {
      "src": "/(css|js|images|videos|build|favicon.ico|robots.txt)(.*)",
      "dest": "/public/$1$2"
    },
    {
      "src": "/",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
